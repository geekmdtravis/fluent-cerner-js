{
  "version": "1.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=14",
    "yarn": "please-use-npm"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsup --lint",
    "prepare": "npm run build",
    "size": "size-limit",
    "analyze": "size-limit --why",
    "demo": "npx node demo.js"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "name": "fluent-cerner-js",
  "author": "geekmdtravis",
  "module": "dist/index.mjs",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "tslib": "^2.8.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.4"
  },
  "peerDependencies": {
    "easy-ccl-request": "^1.0.0"
  },
  "overrides": {
    "vite": {
      "esbuild": "^0.25.0"
    }
  },
  "jest": {
    "verbose": true,
    "silent": true,
    "collectCoverage": true,
    "testPathIgnorePatterns": [
      "index.ts"
    ],
    "coveragePathIgnorePatterns": [
      "index.ts"
    ]
  }
}
